[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

#
# Documentation Files
#

[*.{md,markdown}]
indent_style = space
indent_size = 2

#
# Configuration Files
#

[*.toml]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

#
# Project Source Code
#

[*.{js,ts}]
indent_style = space
indent_size = 4

[*.css]
indent_style = space
indent_size = 4

[*.astro]
indent_style = space
indent_size = 4

[tsconfig.json]
indent_style = space
indent_size = 4
